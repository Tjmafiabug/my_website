---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Tanishq Jain — Ecosystem Builder" description="Ecosystem builder based in Noida. Sourcing startups, building deal pipelines, and connecting founders with capital — at the intersection of deals, data & AI.">
  <!-- HERO SECTION -->
  <section id="hero-section" class="min-h-screen pt-20 flex items-center relative overflow-hidden bg-surface">

    <div class="max-w-7xl mx-auto px-6 py-24 grid md:grid-cols-2 gap-16 items-center w-full">
      <!-- Left -->
      <div class="fade-in">
        <span class="text-primary uppercase tracking-widest text-xs font-semibold font-manrope mb-6 block">Ecosystem Builder · Noida</span>
        <h1 class="font-manrope font-extrabold text-6xl lg:text-7xl tracking-tighter text-on-surface leading-[1.05] mb-6">
          At the Intersection of<br/>Deals, Data <span class="text-primary"><span id="typewriter"></span><span id="tw-cursor">&nbsp;</span></span>
        </h1>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-10 max-w-lg font-inter">
          I source high-signal startups, build deal pipelines, and connect founders with the right capital. Working at the intersection of venture, technology, and intelligent automation.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/story" class="bg-primary text-white font-semibold px-7 py-3.5 rounded-xl hover:bg-on-primary-fixed-variant transition-colors font-inter text-sm">See the Story</a>
          <a href="/gallery" class="border border-outline-variant text-on-surface font-semibold px-7 py-3.5 rounded-xl hover:bg-surface-container-low transition-colors font-inter text-sm">Recent Work</a>
        </div>
      </div>

      <!-- Right — Portrait -->
      <div class="fade-in relative flex justify-center" style="transition-delay: 0.15s">
        <div id="hero-portrait" class="relative">
          <!-- Offset border decoration -->
          <div class="absolute -top-4 -right-4 w-full h-full rounded-[2rem] border-2 border-primary-fixed"></div>
          <div class="absolute -top-2 -right-2 w-full h-full rounded-[2rem] border border-surface-container-high"></div>
          <img
            src="/assets/images/974cbced-1a24-40a1-8e21-31aaa5b963ef.jpg"
            alt="Tanishq Jain — Ecosystem Builder"
            class="relative z-10 w-full max-w-sm rounded-[2rem] object-cover aspect-[3/4] shadow-2xl"
          />
          <!-- Floating chip -->
          <div class="absolute z-20 bottom-6 -left-8 bg-tertiary-container text-on-tertiary-container text-xs font-semibold font-manrope px-4 py-2 rounded-xl shadow-lg">
            DELHI ANGELS ECOSYSTEM
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS SECTION -->
  <section class="bg-surface-container-low py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-start mb-20">
        <!-- Left headline -->
        <div class="fade-in">
          <div class="w-12 h-1 bg-primary rounded-full mb-6"></div>
          <h2 class="font-manrope font-extrabold text-4xl lg:text-5xl tracking-tighter text-on-surface leading-tight">
            Building bridges between founders, capital & opportunity.
          </h2>
        </div>
        <!-- Right body -->
        <div class="fade-in" style="transition-delay:0.1s">
          <p class="text-on-surface-variant leading-relaxed mb-5 font-inter">
            I work closely with <a href="https://kunwersachdev.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Mr. Kunwer Sachdev</a> (The Inverter Man of India) and <a href="https://shivamahuja.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Shivam Ahuja</a> — Founder of <a href="https://skillcircle.in/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">SkillCircle</a> and <a href="https://www.delhiangels.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Delhi Angels</a> — to source and evaluate early-stage startups, identify market opportunities, and connect promising founders with the right investors.
          </p>
          <p class="text-on-surface-variant leading-relaxed font-inter">
            Beyond the deal flow, I study startup ecosystems obsessively, read voraciously, and actively build AI automations and productivity tools — so every hour I put in moves the needle twice as fast.
          </p>
        </div>
      </div>

      <!-- Stat cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="fade-in bg-surface rounded-xl p-8 hover:shadow-lg hover:bg-primary-fixed hover:-translate-y-1 transition-all duration-300 cursor-default">
          <div class="font-manrope font-extrabold text-4xl text-primary mb-2 counter" data-target="100" data-suffix="+">0</div>
          <div class="text-on-surface-variant text-sm font-inter">Startups Evaluated</div>
        </div>
        <div class="fade-in bg-surface rounded-xl p-8 hover:shadow-lg hover:bg-primary-fixed hover:-translate-y-1 transition-all duration-300 cursor-default" style="transition-delay:0.05s">
          <div class="font-manrope font-extrabold text-4xl text-primary mb-2 counter" data-target="50" data-suffix="+">0</div>
          <div class="text-on-surface-variant text-sm font-inter">Investors in Network</div>
        </div>
        <div class="fade-in bg-surface rounded-xl p-8 hover:shadow-lg hover:bg-primary-fixed hover:-translate-y-1 transition-all duration-300 cursor-default" style="transition-delay:0.1s">
          <div class="font-manrope font-extrabold text-4xl text-primary mb-2 counter" data-target="10" data-suffix="+">0</div>
          <div class="text-on-surface-variant text-sm font-inter">AI Tools Built</div>
        </div>
        <div class="fade-in bg-surface rounded-xl p-8 hover:shadow-lg hover:bg-primary-fixed hover:-translate-y-1 transition-all duration-300 cursor-default" style="transition-delay:0.15s">
          <div class="font-manrope font-extrabold text-4xl text-primary mb-2">Delhi</div>
          <div class="text-on-surface-variant text-sm font-inter">Angels Ecosystem</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES SECTION -->
  <section class="bg-surface py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16 fade-in">
        <span class="text-primary uppercase tracking-widest text-xs font-semibold font-manrope block mb-4">How I Show Up</span>
        <h2 class="font-manrope font-extrabold text-4xl lg:text-5xl tracking-tighter text-on-surface max-w-2xl leading-tight">
          Three ways I build the ecosystem.
        </h2>
      </div>

      <!-- 3 service cards -->
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <!-- Card 1 -->
        <div class="fade-in tilt-card bg-surface-container-low rounded-[2rem] p-8 group hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-surface-container rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
            <span class="material-symbols-outlined text-primary group-hover:text-white transition-colors duration-300">search</span>
          </div>
          <h3 class="font-manrope font-bold text-xl text-on-surface mb-3 tracking-tight">Startup Sourcing & Deal Flow</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-inter">Identifying high-potential early-stage startups through deep market research, founder conversations, and ecosystem mapping. Building pipelines that convert curiosity into conviction.</p>
        </div>
        <!-- Card 2 -->
        <div class="fade-in tilt-card bg-surface-container-low rounded-[2rem] p-8 group hover:shadow-lg transition-all duration-300" style="transition-delay:0.08s">
          <div class="w-12 h-12 bg-surface-container rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
            <span class="material-symbols-outlined text-primary group-hover:text-white transition-colors duration-300">hub</span>
          </div>
          <h3 class="font-manrope font-bold text-xl text-on-surface mb-3 tracking-tight">Investor & Operator Networking</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-inter">Connecting founders to the right capital and advisors. I work within the <a href="https://www.delhiangels.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Delhi Angels</a> network and beyond to facilitate introductions that actually move the needle.</p>
        </div>
        <!-- Card 3 -->
        <div class="fade-in tilt-card bg-surface-container-low rounded-[2rem] p-8 group hover:shadow-lg transition-all duration-300" style="transition-delay:0.16s">
          <div class="w-12 h-12 bg-surface-container rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
            <span class="material-symbols-outlined text-primary group-hover:text-white transition-colors duration-300">smart_toy</span>
          </div>
          <h3 class="font-manrope font-bold text-xl text-on-surface mb-3 tracking-tight">AI-Powered Productivity</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-inter">Building automations, custom tools, and AI workflows that eliminate busy work and amplify output. If a process is repeatable, I'm probably automating it.</p>
        </div>
      </div>

      <!-- Dark banner -->
      <div class="fade-in bg-[#131B2E] text-white p-8 rounded-[2rem] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-surface-container-high mb-2 font-manrope">Currently Working With</div>
          <p class="font-manrope font-bold text-xl tracking-tight"><a href="https://kunwersachdev.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Mr. Kunwer Sachdev</a> · <a href="https://shivamahuja.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Shivam Ahuja</a> · <a href="https://www.delhiangels.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Delhi Angels</a></p>
          <p class="text-white/50 text-sm mt-1 font-inter">Sourcing deals, supporting founders, and building the ecosystem.</p>
        </div>
        <a href="mailto:Tanishqjain.work@gmail.com" class="flex items-center gap-2 text-sm font-semibold text-primary-fixed hover:text-white transition-colors font-inter whitespace-nowrap">
          Connect with me <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="py-32 bg-surface-container-low relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/8 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-10 right-20 w-48 h-48 bg-tertiary/10 rounded-full blur-2xl pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <div class="fade-in">
        <h2 class="font-manrope font-extrabold text-5xl lg:text-6xl tracking-tighter text-on-surface mb-6 leading-tight">
          Ready to redefine the <span class="text-primary">narrative?</span>
        </h2>
        <p class="text-on-surface-variant text-lg mb-10 font-inter max-w-lg mx-auto">
          Whether you're a founder, investor, or operator — let's connect and see where the intersection takes us.
        </p>
        <a href="mailto:Tanishqjain.work@gmail.com" class="inline-block bg-primary text-white font-semibold px-8 py-4 rounded-xl hover:bg-on-primary-fixed-variant transition-colors font-inter text-sm">
          Start a Conversation
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  
<script is:inline>

    // ── Scroll-triggered fade-in ─────────────────────────────────────────────
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
    }, { threshold: 0.12 });
    document.querySelectorAll(".fade-in").forEach(el => observer.observe(el));

    // ── 1. Typewriter effect ─────────────────────────────────────────────────
    (function () {
      const el = document.getElementById('typewriter');
      if (!el) return;
      const text = '& AI.';
      let i = 0;
      setTimeout(function type() {
        el.textContent = text.slice(0, i);
        i++;
        if (i <= text.length) setTimeout(type, 80);
      }, 800);
    })();

    // ── 2. Animated counters ─────────────────────────────────────────────────
    (function () {
      const counters = document.querySelectorAll('.counter');
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = parseInt(el.dataset.target, 10);
          const suffix = el.dataset.suffix || '';
          const duration = 1200;
          const step = 16;
          const steps = duration / step;
          let current = 0;
          const increment = target / steps;
          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              el.textContent = target + suffix;
              clearInterval(timer);
            } else {
              el.textContent = Math.floor(current) + suffix;
            }
          }, step);
          counterObserver.unobserve(el);
        });
      }, { threshold: 0.4 });
      counters.forEach(c => counterObserver.observe(c));
    })();

    // ── 3. Parallax on hero portrait ─────────────────────────────────────────
    (function () {
      const portrait = document.getElementById('hero-portrait');
      if (!portrait) return;
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        portrait.style.transform = `translateY(${scrollY * 0.12}px)`;
      }, { passive: true });
    })();

// ── 5. Service cards 3D tilt ─────────────────────────────────────────────
    (function () {
      document.querySelectorAll('.tilt-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const cx = rect.width / 2;
          const cy = rect.height / 2;
          const rotateX = ((y - cy) / cy) * -8;
          const rotateY = ((x - cx) / cx) * 8;
          card.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)';
          card.style.transition = 'transform 0.4s ease';
        });
        card.addEventListener('mouseenter', () => {
          card.style.transition = 'transform 0.1s ease';
        });
      });
    })();
  
</script>

</BaseLayout>
