---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

const gallery = await getCollection('gallery');
// Sort by date (we can add a timestamp to frontmatter for better sorting, but for now we'll just show them)
---
<BaseLayout title="Gallery — Tanishq Jain | Events & Startup Ecosystem" description="Photos from startup events, investor panels, and ecosystem moments — Tanishq Jain at TiE Delhi NCR, Bundelkhand Venture Summit, and more.">
  <!-- HERO -->
  <section class="pt-20 min-h-[40vh] flex items-center bg-surface">
    <div class="max-w-7xl mx-auto px-6 py-16 w-full">
      <div class="fade-in">
        <span class="text-primary uppercase tracking-widest text-xs font-semibold font-manrope block mb-5">In the Room</span>
        <h1 class="font-manrope font-extrabold text-6xl lg:text-7xl tracking-tighter text-on-surface leading-[1.0] mb-4">
          Moments &<br/><span class="text-primary">Milestones.</span>
        </h1>
        <p class="text-on-surface-variant text-lg font-inter max-w-lg">
          Events, panels, and rooms I've been a part of — building the ecosystem one conversation at a time.
        </p>
      </div>
    </div>
  </section>

  <!-- FILTER TABS -->
  <section class="bg-surface border-b border-outline-variant sticky top-20 z-40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex gap-1 overflow-x-auto py-3">
        <button class="gallery-filter flex-shrink-0 text-xs font-bold px-4 py-2 rounded-full font-manrope transition-all bg-primary text-white" data-filter="all">All</button>
        <button class="gallery-filter flex-shrink-0 text-xs font-bold px-4 py-2 rounded-full font-manrope transition-all bg-surface-container text-on-surface-variant hover:bg-surface-container-high" data-filter="events">Events</button>
        <button class="gallery-filter flex-shrink-0 text-xs font-bold px-4 py-2 rounded-full font-manrope transition-all bg-surface-container text-on-surface-variant hover:bg-surface-container-high" data-filter="photography">Photography</button>
      </div>
    </div>
  </section>

  <!-- EVENT CARDS GRID -->
  <section class="bg-surface-container-low py-10">
    <div class="max-w-7xl mx-auto px-6">
      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        {gallery.map(item => (
          <div class="event-card group cursor-pointer fade-in" 
            data-category={item.data.category}
            data-photos={JSON.stringify(item.data.photos.map(p => p.src))}
            data-label={item.data.title}
            data-date={item.data.date}
            data-desc={item.data.description}>
            <div class="relative overflow-hidden rounded-2xl bg-surface-container">
              <div class="aspect-video overflow-hidden">
                <Image src={item.data.cover} alt={item.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="absolute top-3 right-3 bg-surface/80 backdrop-blur-sm text-on-surface text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1 border border-surface-container-high">
                <span class="material-symbols-outlined text-xs text-primary" style="font-size:12px">photo_library</span>
                {item.data.photos.length} photos
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">
                    {item.data.category === 'events' ? 'Event' : 'Photography'}
                  </span>
                  <span class="text-on-surface-variant text-[10px] font-inter">{item.data.date}</span>
                </div>
                <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">{item.data.title}</h3>
                <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">{item.data.description}</p>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- LIGHTBOX (Light Mode) -->
  <div id="lightbox" class="fixed inset-0 bg-surface/98 backdrop-blur-xl z-50 hidden items-center justify-center p-4">
    <button id="lightbox-close" class="absolute top-5 right-5 text-on-surface-variant hover:text-primary transition-colors z-10">
      <span class="material-symbols-outlined text-3xl">close</span>
    </button>
    <!-- Prev -->
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors z-10">
      <span class="material-symbols-outlined text-4xl">chevron_left</span>
    </button>
    <!-- Next -->
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors z-10">
      <span class="material-symbols-outlined text-4xl">chevron_right</span>
    </button>
    <div class="max-w-4xl w-full text-center">
      <img id="lightbox-img" src="" alt="" class="w-full h-auto max-h-[75vh] object-contain rounded-2xl mx-auto" />
      <div class="mt-4">
        <p id="lightbox-label" class="text-on-surface font-semibold font-manrope text-sm"></p>
        <p id="lightbox-counter" class="text-on-surface-variant font-inter text-xs mt-1"></p>
      </div>
    </div>
  </div>

  <!-- CTA BANNER -->
  <section class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="fade-in relative overflow-hidden rounded-[2rem] p-12 bg-gradient-to-br from-primary to-primary-container">
        <div class="absolute -top-10 -right-10 w-64 h-64 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-1/4 w-48 h-48 bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
          <div>
            <h2 class="font-manrope font-extrabold text-3xl lg:text-4xl text-white tracking-tighter mb-3">
              Want to be in the same room?
            </h2>
            <p class="text-white/80 font-inter text-sm max-w-md">
              Whether it's a panel, a pitch, or just a conversation — let's connect.
            </p>
          </div>
          <div class="flex flex-wrap gap-4 shrink-0">
            <a href="/contact" class="bg-white text-primary font-semibold px-6 py-3 rounded-xl text-sm hover:bg-primary-fixed transition-colors font-inter">
              Get in Touch
            </a>
            <a href="/story" class="border border-white/40 text-white font-semibold px-6 py-3 rounded-xl text-sm hover:bg-white/10 transition-colors font-inter">
              Read the Story
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  
<script is:inline>
  document.addEventListener('astro:page-load', () => {

    // ── Fade-in ───────────────────────────────────────────────────────────────
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08 });
    document.querySelectorAll(".fade-in").forEach(el => observer.observe(el));

    // ── Filter ────────────────────────────────────────────────────────────────
    document.querySelectorAll('.gallery-filter').forEach(f => {
      f.addEventListener('click', () => {
        document.querySelectorAll('.gallery-filter').forEach(p => {
          p.classList.remove('bg-primary', 'text-white');
          p.classList.add('bg-surface-container', 'text-on-surface-variant');
        });
        f.classList.add('bg-primary', 'text-white');
        f.classList.remove('bg-surface-container', 'text-on-surface-variant');
        const cat = f.dataset.filter;
        document.querySelectorAll('.event-card').forEach(card => {
          card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
        });
      });
    });

    // ── Lightbox with prev/next ───────────────────────────────────────────────
    const lightbox = document.getElementById('lightbox');
    if (!lightbox) return;
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxLabel = document.getElementById('lightbox-label');
    const lightboxCounter = document.getElementById('lightbox-counter');

    let currentPhotos = [];
    let currentIndex = 0;

    function showPhoto(index) {
      currentIndex = index;
      lightboxImg.src = currentPhotos[index];
      lightboxImg.alt = lightboxLabel.textContent || "Gallery image";
      lightboxCounter.textContent = (currentPhotos.length > 1) ? `${index + 1} / ${currentPhotos.length}` : '';
      document.getElementById('lightbox-prev').style.display = currentPhotos.length > 1 ? '' : 'none';
      document.getElementById('lightbox-next').style.display = currentPhotos.length > 1 ? '' : 'none';
    }

    document.querySelectorAll('.event-card').forEach(card => {
      card.addEventListener('click', () => {
        currentPhotos = JSON.parse(card.dataset.photos);
        lightboxLabel.textContent = card.dataset.label || '';
        showPhoto(0);
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    document.getElementById('lightbox-prev').addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto((currentIndex - 1 + currentPhotos.length) % currentPhotos.length);
    });
    document.getElementById('lightbox-next').addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto((currentIndex + 1) % currentPhotos.length);
    });
    document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    
    // Keydown listener needs to be outside or managed carefully to avoid duplicates
    // But for simplicity in is:inline we'll just check if it exists or use page-load
    function handleGalleryKeys(e) {
      if (!lightbox || lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showPhoto((currentIndex + 1) % currentPhotos.length);
      if (e.key === 'ArrowLeft') showPhoto((currentIndex - 1 + currentPhotos.length) % currentPhotos.length);
    }
    document.addEventListener('keydown', handleGalleryKeys);

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }
  });
</script>

</BaseLayout>
