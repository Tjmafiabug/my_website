---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Gallery — Tanishq Jain | Events & Startup Ecosystem" description="Photos from startup events, investor panels, and ecosystem moments — Tanishq Jain at TiE Delhi NCR, Bundelkhand Venture Summit, and more.">
  <!-- HERO -->
  <section class="pt-20 min-h-[40vh] flex items-center bg-surface">
    <div class="max-w-7xl mx-auto px-6 py-16 w-full">
      <div class="fade-in">
        <span class="text-primary uppercase tracking-widest text-xs font-semibold font-manrope block mb-5">In the Room</span>
        <h1 class="font-manrope font-extrabold text-6xl lg:text-7xl tracking-tighter text-on-surface leading-[1.0] mb-4">
          Moments &<br/><span class="text-primary">Milestones.</span>
        </h1>
        <p class="text-on-surface-variant text-lg font-inter max-w-lg">
          Events, panels, and rooms I've been a part of — building the ecosystem one conversation at a time.
        </p>
      </div>
    </div>
  </section>

  <!-- FILTER TABS -->
  <section class="bg-surface border-b border-outline-variant sticky top-20 z-40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex gap-1 overflow-x-auto py-3">
        <button class="gallery-filter flex-shrink-0 text-xs font-bold px-4 py-2 rounded-full font-manrope transition-all bg-primary text-white" data-filter="all">All</button>
        <button class="gallery-filter flex-shrink-0 text-xs font-bold px-4 py-2 rounded-full font-manrope transition-all bg-surface-container text-on-surface-variant hover:bg-surface-container-high" data-filter="events">Events</button>
        <button class="gallery-filter flex-shrink-0 text-xs font-bold px-4 py-2 rounded-full font-manrope transition-all bg-surface-container text-on-surface-variant hover:bg-surface-container-high" data-filter="photography">Photography</button>
      </div>
    </div>
  </section>

  <!-- EVENT CARDS GRID -->
  <section class="bg-surface-container-low py-10">
    <div class="max-w-7xl mx-auto px-6">
      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- EVENT CARD: Bundelkhand Venture Summit 2026 -->
        <div class="event-card group cursor-pointer fade-in" data-category="events"
          data-photos='["/assets/images/IMG_0465.jpg","/assets/images/IMG_0470.jpg","/assets/images/IMG_0473.JPG"]'
          data-label="Bundelkhand Venture Summit 2026"
          data-date="Feb 28 – Mar 1, 2026"
          data-desc="Invited as an investor and panelist — panel discussion on startups and fundraising.">
          <div class="relative overflow-hidden rounded-2xl bg-surface-container">
            <!-- Cover photo -->
            <div class="aspect-video overflow-hidden">
              <img src="/assets/images/IMG_0470.jpg" alt="Bundelkhand Venture Summit 2026"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <!-- Photo count badge -->
            <div class="absolute top-3 right-3 bg-[#131B2E]/70 backdrop-blur-sm text-white text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="material-symbols-outlined text-xs" style="font-size:12px">photo_library</span>
              3 photos
            </div>
            <!-- Bottom info -->
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">Event</span>
                <span class="text-on-surface-variant text-[10px] font-inter">Feb 28 – Mar 1, 2026</span>
              </div>
              <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">Bundelkhand Venture Summit 2026</h3>
              <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">Invited as investor & panelist — discussion on startups and fundraising.</p>
            </div>
          </div>
        </div>

        <!-- EVENT CARD: startupnews.fyi Pitching Event -->
        <div class="event-card group cursor-pointer fade-in" data-category="events"
          data-photos='["/assets/images/IMG_0553.jpg","/assets/images/IMG_0661.jpg"]'
          data-label="Pitching Event by startupnews.fyi — Ofis Square, Gurgaon"
          data-date="March 21, 2026"
          data-desc="Attended as investor alongside investors from Angel Bay, Madhukar Bhardwaj, SwiftSeed, Soonicorn Venture and many more.">
          <div class="relative overflow-hidden rounded-2xl bg-surface-container">
            <div class="aspect-video overflow-hidden">
              <img src="/assets/images/IMG_0553.jpg" alt="startupnews.fyi Pitching Event Gurgaon"
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="absolute top-3 right-3 bg-[#131B2E]/70 backdrop-blur-sm text-white text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="material-symbols-outlined" style="font-size:12px">photo_library</span>
              2 photos
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">Event</span>
                <span class="text-on-surface-variant text-[10px] font-inter">March 21, 2026</span>
              </div>
              <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">Pitching Event — startupnews.fyi</h3>
              <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">Attended as investor at Ofis Square, Gurgaon alongside Angel Bay, SwiftSeed, Soonicorn Venture and more.</p>
            </div>
          </div>
        </div>

        <!-- EVENT CARD: TiE Delhi NCR -->
        <div class="event-card group cursor-pointer fade-in" data-category="events"
          data-photos='["/assets/images/IMG_0126.jpg","/assets/images/IMG_0130.jpg","/assets/images/IMG_0134.jpg","/assets/images/IMG_0138.jpg"]'
          data-label="TiE Delhi NCR — IHC, New Delhi"
          data-date="February 25, 2026"
          data-desc="Met Madhur (startupnews.fyi founder), Vineet Sagar (Venture Garage), Blue Tea founder, Nitesh, and many more ecosystem builders.">
          <div class="relative overflow-hidden rounded-2xl bg-surface-container">
            <div class="aspect-video overflow-hidden">
              <img src="/assets/images/IMG_0138.jpg" alt="TiE Delhi NCR event at IHC Delhi"
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="absolute top-3 right-3 bg-[#131B2E]/70 backdrop-blur-sm text-white text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="material-symbols-outlined" style="font-size:12px">photo_library</span>
              4 photos
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">Event</span>
                <span class="text-on-surface-variant text-[10px] font-inter">February 25, 2026</span>
              </div>
              <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">TiE Delhi NCR</h3>
              <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">IHC, New Delhi — in a room full of investors and founders, while IIM interviews were being conducted next door.</p>
            </div>
          </div>
        </div>

        <!-- EVENT CARD: Pitch in 180 Seconds — Sharda University -->
        <div class="event-card group cursor-pointer fade-in" data-category="events"
          data-photos='["/assets/images/IMG_0067.jpg","/assets/images/IMG_7772.JPG","/assets/images/IMG_7777.JPG"]'
          data-label="Pitch in 180 Seconds — Sharda University"
          data-date="February 23, 2026"
          data-desc="Attended as investor alongside Shivam Ahuja and other angel investors. Founders had 180 seconds to make their case.">
          <div class="relative overflow-hidden rounded-2xl bg-surface-container">
            <div class="aspect-video overflow-hidden">
              <img src="/assets/images/IMG_7777.JPG" alt="Pitch in 180 Seconds at Sharda University"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" style="object-position: center 20%;" />
            </div>
            <div class="absolute top-3 right-3 bg-[#131B2E]/70 backdrop-blur-sm text-white text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="material-symbols-outlined" style="font-size:12px">photo_library</span>
              3 photos
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">Event</span>
                <span class="text-on-surface-variant text-[10px] font-inter">February 23, 2026</span>
              </div>
              <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">Pitch in 180 Seconds — Sharda University</h3>
              <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">Attended as investor alongside <a href="https://shivamahuja.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Shivam Ahuja</a> and other angel investors. Founders had 180 seconds to make their case.</p>
            </div>
          </div>
        </div>

        <!-- EVENT CARD: Digital Inclusion Summit 2026 -->
        <div class="event-card group cursor-pointer fade-in" data-category="events"
          data-photos='["/assets/images/IMG_2624.jpg","/assets/images/IMG_2626.jpg","/assets/images/IMG_2630.jpg","/assets/images/IMG_2634.jpg"]'
          data-label="Digital Inclusion Summit 2026 — Le Meridien, New Delhi"
          data-date="February 6, 2026"
          data-desc="Attended the Digital Inclusion Summit 2026 at Le Meridien, New Delhi.">
          <div class="relative overflow-hidden rounded-2xl bg-surface-container">
            <div class="aspect-video overflow-hidden">
              <img src="/assets/images/IMG_2634.jpg" alt="Digital Inclusion Summit 2026"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" style="object-position: center 45%;" />
            </div>
            <div class="absolute top-3 right-3 bg-[#131B2E]/70 backdrop-blur-sm text-white text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="material-symbols-outlined" style="font-size:12px">photo_library</span>
              4 photos
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">Event</span>
                <span class="text-on-surface-variant text-[10px] font-inter">February 6, 2026</span>
              </div>
              <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">Digital Inclusion Summit 2026</h3>
              <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">Le Meridien, New Delhi — summit on digital inclusion and the future of technology in India.</p>
            </div>
          </div>
        </div>

        <!-- EVENT CARD: Entrepreneur Awards 2026 -->
        <div class="event-card group cursor-pointer fade-in" data-category="events"
          data-photos='["/assets/images/IMG_2583.jpg","/assets/images/IMG_3809.JPG","/assets/images/b2b5f2ac-b5fd-4938-b971-0946f29c9b27.JPG"]'
          data-label="Entrepreneur Awards 2026 — Bharat Mandapam, New Delhi"
          data-date="February 5, 2026"
          data-desc="Attended with Shivam Ahuja and Kunwer Sachdev. Shivam was awarded Best Skill Education EdTech Startup.">
          <div class="relative overflow-hidden rounded-2xl bg-surface-container">
            <div class="aspect-video overflow-hidden">
              <img src="/assets/images/b2b5f2ac-b5fd-4938-b971-0946f29c9b27.JPG" alt="Entrepreneur Awards 2026 at Bharat Mandapam"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" style="object-position: center 30%;" />
            </div>
            <div class="absolute top-3 right-3 bg-[#131B2E]/70 backdrop-blur-sm text-white text-[10px] font-bold font-manrope px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="material-symbols-outlined" style="font-size:12px">photo_library</span>
              3 photos
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-primary-fixed text-primary text-[10px] font-bold px-2 py-0.5 rounded-full font-manrope">Event</span>
                <span class="text-on-surface-variant text-[10px] font-inter">February 5, 2026</span>
              </div>
              <h3 class="font-manrope font-bold text-sm text-on-surface tracking-tight">Entrepreneur Awards 2026</h3>
              <p class="text-on-surface-variant text-xs font-inter mt-1 leading-relaxed">Bharat Mandapam, New Delhi — <a href="https://shivamahuja.com/" target="_blank" rel="noopener" class="text-on-primary-fixed-variant underline decoration-primary/40 hover:decoration-primary transition-all">Shivam Ahuja</a> awarded Best Skill Education EdTech Startup.</p>
            </div>
          </div>
        </div>

        <!-- ADD NEW EVENTS BELOW THIS LINE -->

      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="fixed inset-0 bg-[#131B2E]/95 z-50 hidden items-center justify-center p-4">
    <button id="lightbox-close" class="absolute top-5 right-5 text-white/60 hover:text-white transition-colors z-10">
      <span class="material-symbols-outlined text-3xl">close</span>
    </button>
    <!-- Prev -->
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors z-10">
      <span class="material-symbols-outlined text-4xl">chevron_left</span>
    </button>
    <!-- Next -->
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors z-10">
      <span class="material-symbols-outlined text-4xl">chevron_right</span>
    </button>
    <div class="max-w-4xl w-full text-center">
      <img id="lightbox-img" src="" alt="" class="w-full h-auto max-h-[75vh] object-contain rounded-2xl mx-auto" />
      <div class="mt-4">
        <p id="lightbox-label" class="text-white font-semibold font-manrope text-sm"></p>
        <p id="lightbox-counter" class="text-white/40 font-inter text-xs mt-1"></p>
      </div>
    </div>
  </div>

  <!-- CTA BANNER -->
  <section class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="fade-in relative overflow-hidden rounded-[2rem] p-12 bg-gradient-to-br from-primary to-primary-container">
        <div class="absolute -top-10 -right-10 w-64 h-64 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-1/4 w-48 h-48 bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
          <div>
            <h2 class="font-manrope font-extrabold text-3xl lg:text-4xl text-white tracking-tighter mb-3">
              Want to be in the same room?
            </h2>
            <p class="text-white/80 font-inter text-sm max-w-md">
              Whether it's a panel, a pitch, or just a conversation — let's connect.
            </p>
          </div>
          <div class="flex flex-wrap gap-4 shrink-0">
            <a href="/contact" class="bg-white text-primary font-semibold px-6 py-3 rounded-xl text-sm hover:bg-primary-fixed transition-colors font-inter">
              Get in Touch
            </a>
            <a href="/story" class="border border-white/40 text-white font-semibold px-6 py-3 rounded-xl text-sm hover:bg-white/10 transition-colors font-inter">
              Read the Story
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  
<script is:inline>

    // ── Fade-in ───────────────────────────────────────────────────────────────
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08 });
    document.querySelectorAll(".fade-in").forEach(el => observer.observe(el));

    // ── Filter ────────────────────────────────────────────────────────────────
    document.querySelectorAll('.gallery-filter').forEach(f => {
      f.addEventListener('click', () => {
        document.querySelectorAll('.gallery-filter').forEach(p => {
          p.classList.remove('bg-primary', 'text-white');
          p.classList.add('bg-surface-container', 'text-on-surface-variant');
        });
        f.classList.add('bg-primary', 'text-white');
        f.classList.remove('bg-surface-container', 'text-on-surface-variant');
        const cat = f.dataset.filter;
        document.querySelectorAll('.event-card').forEach(card => {
          card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
        });
      });
    });

    // ── Lightbox with prev/next ───────────────────────────────────────────────
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxLabel = document.getElementById('lightbox-label');
    const lightboxCounter = document.getElementById('lightbox-counter');

    let currentPhotos = [];
    let currentIndex = 0;

    function showPhoto(index) {
      currentIndex = index;
      lightboxImg.src = currentPhotos[index];
      lightboxImg.alt = lightboxLabel.textContent || "Gallery image";
      lightboxCounter.textContent = (currentPhotos.length > 1) ? `${index + 1} / ${currentPhotos.length}` : '';
      document.getElementById('lightbox-prev').style.display = currentPhotos.length > 1 ? '' : 'none';
      document.getElementById('lightbox-next').style.display = currentPhotos.length > 1 ? '' : 'none';
    }

    document.querySelectorAll('.event-card').forEach(card => {
      card.addEventListener('click', () => {
        currentPhotos = JSON.parse(card.dataset.photos);
        lightboxLabel.textContent = card.dataset.label || '';
        showPhoto(0);
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    document.getElementById('lightbox-prev').addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto((currentIndex - 1 + currentPhotos.length) % currentPhotos.length);
    });
    document.getElementById('lightbox-next').addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto((currentIndex + 1) % currentPhotos.length);
    });
    document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showPhoto((currentIndex + 1) % currentPhotos.length);
      if (e.key === 'ArrowLeft') showPhoto((currentIndex - 1 + currentPhotos.length) % currentPhotos.length);
    });
    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }
  
</script>

</BaseLayout>
