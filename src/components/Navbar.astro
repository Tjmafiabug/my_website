---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove leading slash
---
<nav class="fixed top-0 left-0 right-0 z-50 h-20 bg-[#FAF8FF]/80 backdrop-blur-xl border-b border-[#F2F3FF]" transition:name="navbar" transition:persist>
  <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">
    <a href="/" class="font-manrope font-extrabold text-xl tracking-tighter text-on-surface">Tanishq Jain</a>
    <div class="hidden md:flex items-center gap-8 nav-links">
      <a href="/" data-path="" class="text-sm font-medium transition-colors text-on-surface-variant hover:text-primary">Home</a>
      <a href="/story" data-path="story" class="text-sm font-medium transition-colors text-on-surface-variant hover:text-primary">Story</a>
      <a href="/journey" data-path="journey" class="text-sm font-medium transition-colors text-on-surface-variant hover:text-primary">Journey</a>
      <a href="/gallery" data-path="gallery" class="text-sm font-medium transition-colors text-on-surface-variant hover:text-primary">Gallery</a>
      <a href="/blog" data-path="blog" class="text-sm font-medium transition-colors text-on-surface-variant hover:text-primary">Blog</a>
      <a href="/contact" class="bg-primary text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:bg-[#003EA8] transition-colors">Contact Me</a>
    </div>
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="block w-6 h-0.5 bg-on-surface transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-on-surface transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-on-surface transition-all duration-300" id="bar3"></span>
    </button>
  </div>
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#FAF8FF]/95 backdrop-blur-xl px-6 pb-6 border-b border-[#F2F3FF]">
    <div class="flex flex-col gap-4 pt-4 mobile-nav-links">
      <a href="/" data-path="" class="text-sm font-medium text-on-surface-variant">Home</a>
      <a href="/story" data-path="story" class="text-sm font-medium text-on-surface-variant">Story</a>
      <a href="/journey" data-path="journey" class="text-sm font-medium text-on-surface-variant">Journey</a>
      <a href="/gallery" data-path="gallery" class="text-sm font-medium text-on-surface-variant">Gallery</a>
      <a href="/blog" data-path="blog" class="text-sm font-medium text-on-surface-variant">Blog</a>
      <a href="/contact" class="bg-primary text-white text-sm font-semibold px-5 py-2.5 rounded-xl text-center">Contact Me</a>
    </div>
  </div>
</nav>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // ── Update Active Links ──────────────────────────────────────────────────
    const pathname = window.location.pathname;
    const currentPath = pathname.slice(1).split('/')[0]; // get base path segment

    const updateActiveLinks = (containerSelector, activeClasses, baseClasses) => {
      document.querySelectorAll(`${containerSelector} a[data-path]`).forEach(link => {
        const linkPath = link.dataset.path;
        const isActive = linkPath === "" ? pathname === "/" : pathname.startsWith(`/${linkPath}`);
        
        if (isActive) {
          link.className = `text-sm font-medium transition-colors ${activeClasses}`;
        } else {
          link.className = `text-sm font-medium transition-colors ${baseClasses}`;
        }
      });
    };

    // Update Desktop Links
    updateActiveLinks('.nav-links', 'text-primary border-b-2 border-primary pb-0.5', 'text-on-surface-variant hover:text-primary');
    // Update Mobile Links
    updateActiveLinks('.mobile-nav-links', 'text-primary', 'text-on-surface-variant');

    // ── Mobile Menu Toggle ───────────────────────────────────────────────────
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');
    let open = false;
    
    if (btn && menu) {
      menu.classList.add('hidden');
      btn.addEventListener('click', () => {
        open = !open;
        menu.classList.toggle('hidden', !open);
        if (open) {
          bar1.style.transform = 'translateY(8px) rotate(45deg)';
          bar2.style.opacity = '0';
          bar3.style.transform = 'translateY(-8px) rotate(-45deg)';
        } else {
          bar1.style.transform = '';
          bar2.style.opacity = '';
          bar3.style.transform = '';
        }
      });
    }

    document.querySelectorAll("#mobile-menu a").forEach(link => {
      link.addEventListener("click", () => {
        if (menu) menu.classList.add("hidden");
        open = false;
        if (bar1) bar1.style.transform = "";
        if (bar2) bar2.style.opacity = "";
        if (bar3) bar3.style.transform = "";
      });
    });
  });
</script>
